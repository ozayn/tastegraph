# TasteGraph API
# Copy to .env and adjust as needed

APP_NAME=TasteGraph API
DEBUG=false

# PostgreSQL (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://localhost:5432/tastegraph

# CORS (Railway: set to your frontend URL, e.g. https://yourapp.railway.app)
CORS_ORIGINS=http://localhost:3000

# OMDb API (optional, for metadata enrichment)
# Get key at https://www.omdbapi.com/
OMDB_API_KEY=
# Fallback key; used on key/quota/rate-limit error
OMDB_API_KEY_FALLBACK=
ADMIN_IMPORT_TOKEN=

# LLM search (optional, for natural-language watchlist search)
# Get key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant